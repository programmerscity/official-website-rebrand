# Turn on the rewrite engine
RewriteEngine On

# 1. Remove .php from existing URLs (Redirects about.php -> about)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.php [NC]
RewriteRule ^ %1 [R=301,L]

# 2. Map folder-like requests to .php files (Internal rewrite about -> about.php)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*?)/?$ $1.php [L]
