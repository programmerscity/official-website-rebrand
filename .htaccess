# Turn on the rewrite engine
RewriteEngine On

# Force HTTPS except on localhost (commented for localhost development)
RewriteCond %{HTTP_HOST} !^localhost$ [NC]
RewriteCond %{HTTP_HOST} !^127\.0\.0\.1$ [NC]
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# Remove trailing slashes (optional but good for SEO)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} (.+)/$
RewriteRule ^ %1 [R=301,L]

# 1. Remove /public/ from the URL (internally rewrite to public directory)
# 2. Remove .php extension (show page without extension)

# First, check if request is for an existing file/directory/link
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-l

# Then, internally rewrite to public/{request}.php
# Example: /about -> public/about.php
# Example: /services -> public/services.php
RewriteRule ^([^/.]+)$ public/$1.php [L]

# Handle URLs with optional trailing slash
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-l
RewriteRule ^([^/.]+)/$ public/$1.php [L]

# Handle subdirectories (if you have any inside public)
# Example: /admin/dashboard -> public/admin/dashboard.php
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-l
RewriteRule ^([^/]+)/([^/.]+)$ public/$1/$2.php [L]

# Redirect any direct access to public/ or .php files back to clean URL
# This ensures search engines don't index duplicate content

# Redirect /public/page to /page
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/public/([^.\s]+)\.php [NC]
RewriteRule ^ /%1 [R=301,L]

# Redirect /page.php to /page
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.\s]+)\.php [NC]
RewriteRule ^ /%1 [R=301,L]

# Optional: Set the default index page
DirectoryIndex public/index.php

# Optional: Prevent directory listing
Options -Indexes